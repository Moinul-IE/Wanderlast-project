<% layout("/layouts/boilerplate") %>
<body>
    <h3>All listings</h3>
    <!-- <form method="GET" action="/listings/new">
        <button>Create a New Listing</button>
    </form> -->

<!-- card add in  -->
 <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1">
    <%  for (const listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing_card">
            <div class="card col" style="width: 16rem;">
                <img src=" <%= listing.image %> " class="card-img-top" alt="listing_image" style=" height: 18rem;">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                  <p class="card-text">
                   <b> <%= listing.title %></b> <br>
                    &#2547; <%= listing.price.toLocaleString("en-IN") %>
                  </p>
                </div>
              </div>
        </a>
       
          <% } %> 
 </div>














</body>
</html>